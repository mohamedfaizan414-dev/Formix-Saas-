NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Groq Cloud AI Engine (used for form builder AI prompt generations)
GROQ_API_KEY=

# SMTP Mail Server settings (Nodemailer)
