generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  AMENDED
}

enum FormAssignmentStatus {
  PENDING
  SUBMITTED
}

model Hospital {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Department[]
  users       User[]
  forms       Form[]
  templates   Template[]
  submissions Submission[]
  auditLogs   AuditLog[]
  patients    Patient[]

  @@map("hospitals")
}

model Department {
  id         String   @id @default(cuid()) @map("_id")
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime @default(now())

  forms Form[]
  users User[]

  @@unique([hospitalId, name])
  @@map("departments")
}

model Role {
  id            String       @id @default(cuid()) @map("_id")
  name          RoleName     @unique
  description   String?
  permissionIds String[]
  permissions   Permission[] @relation("RolePermissions", fields: [permissionIds], references: [id])
  users         User[]

  @@map("roles")
}

model Permission {
  id      String   @id @default(cuid()) @map("_id")
  key     String   @unique
  label   String
  roleIds String[]
  roles   Role[]   @relation("RolePermissions", fields: [roleIds], references: [id])

  @@map("permissions")
}

model User {
  id           String      @id @default(cuid()) @map("_id")
  email        String      @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean     @default(true)
  mfaEnabled   Boolean     @default(false)
  mfaSecret    String?
  hospitalId   String?
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  createdForms       Form[]           @relation("FormCreatedBy")
  createdVersions    FormVersion[]    @relation("VersionCreatedBy")
  submissions        Submission[]     @relation("SubmittedBy")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  uploadedFiles      FileAsset[]
  notifications      Notification[]
  assignedForms      FormAssignment[] @relation("FormAssignedBy")

  @@index([hospitalId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Form {
  id             String      @id @default(cuid()) @map("_id")
  hospitalId     String
  hospital       Hospital    @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  name           String
  slug           String
  description    String?
  category       String?
  status         FormStatus  @default(DRAFT)
  currentVersion Int         @default(1)
  createdById    String
  createdBy      User        @relation("FormCreatedBy", fields: [createdById], references: [id])
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  versions    FormVersion[]
  submissions Submission[]
  assignments FormAssignment[]

  @@unique([hospitalId, slug])
  @@index([hospitalId, status])
  @@map("forms")
}

model FormVersion {
  id            String    @id @default(cuid()) @map("_id")
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  versionNumber Int
  schema        Json
  changelog     String?
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdById   String
  createdBy     User      @relation("VersionCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())

  submissions Submission[]
  assignments FormAssignment[]

  @@unique([formId, versionNumber])
  @@map("form_versions")
}

model Template {
  id          String    @id @default(cuid()) @map("_id")
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  name        String
  category    String
  description String?
  schema      Json
  thumbnail   String?
  createdAt   DateTime  @default(now())

  @@map("templates")
}

model Submission {
  id            String            @id @default(cuid()) @map("_id")
  formId        String
  form          Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersionId String
  formVersion   FormVersion       @relation(fields: [formVersionId], references: [id])
  hospitalId    String
  hospital      Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patientId     String?
  encounterId   String?
  status        SubmissionStatus  @default(DRAFT)
  data          Json
  submittedById String
  submittedBy   User              @relation("SubmittedBy", fields: [submittedById], references: [id])
  submittedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  history SubmissionVersion[]

  @@index([hospitalId, formId])
  @@index([patientId])
  @@map("submissions")
}

model SubmissionVersion {
  id           String     @id @default(cuid()) @map("_id")
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  data         Json
  editedById   String
  createdAt    DateTime   @default(now())

  @@map("submission_versions")
}

model FileAsset {
  id           String   @id @default(cuid()) @map("_id")
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  url          String
  publicId     String
  resourceType String
  originalName String?
  bytes        Int?
  createdAt    DateTime @default(now())

  @@map("files")
}

model AuditLog {
  id         String    @id @default(cuid()) @map("_id")
  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([hospitalId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Patient {
  id             String   @id @default(cuid()) @map("_id")
  email          String
  firstName      String?
  lastName       String?
  phone          String?
  organizationId String
  hospital       Hospital @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments FormAssignment[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("patients")
}

model FormAssignment {
  id            String               @id @default(cuid()) @map("_id")
  token         String               @unique @default(uuid())
  patientId     String
  patient       Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  formId        String
  form          Form                 @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersionId String
  formVersion   FormVersion          @relation(fields: [formVersionId], references: [id])
  formTitle     String
  status        FormAssignmentStatus @default(PENDING)
  assignedById  String
  assignedBy    User                 @relation("FormAssignedBy", fields: [assignedById], references: [id])
  sentAt        DateTime             @default(now())
  submittedAt   DateTime?
  payload       Json?

  @@index([patientId])
  @@index([formId])
  @@map("form_assignments")
}
